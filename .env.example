
# --- Entorno ---
APP_ENV=production


# --- Base de datos ---
DATABASE_URL=postgresql://usuario:password@host:5432/dbname


# --- Seguridad JWT ---
SECRET_KEY=clave-fuerte
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# --- Usuario admin inicial ---
ADMIN_EMAIL=dummy@correo.com
ADMIN_PASSWORD=dummy-contraseña-fuerte


# --- IA (Anthropic) ---
ANTHROPIC_API_KEY=

# Modelo a usar:
#   - claude-haiku-4-5-20251001  
#   - claude-sonnet-4-6         
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Tope de tokens por respuesta 
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=20


# --- CORS (solo para desarrollo local) ---
CORS_ORIGINS=


# --- Puerto ---
PORT=8000
